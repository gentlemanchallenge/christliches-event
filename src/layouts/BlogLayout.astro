---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    author: string;
    tags: string[];
    image: string;
    imageAlt: string;
  };
}

const { frontmatter } = Astro.props;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": frontmatter.title,
  "description": frontmatter.description,
  "image": `https://christliches-event.de${frontmatter.image}`,
  "datePublished": frontmatter.pubDate,
  "author": { "@type": "Organization", "name": frontmatter.author },
  "publisher": { "@type": "Organization", "name": "christliches-event.de", "url": "https://christliches-event.de" },
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogImage={frontmatter.image}
  ogType="article"
  article={{ publishedTime: frontmatter.pubDate, author: frontmatter.author, tags: frontmatter.tags }}
  jsonLd={articleJsonLd}
>
  <section class="bg-primary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-14 sm:pb-16">
      <div class="mb-5">
        <Breadcrumbs items={[{ label: 'Ratgeber', href: '/blog' }, { label: frontmatter.title }]} />
      </div>
      <div class="flex flex-wrap gap-2 mb-4">
        {frontmatter.tags.map((tag) => (
          <span class="px-2.5 py-0.5 bg-white/10 text-white/70 text-xs rounded">{tag}</span>
        ))}
      </div>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-[family-name:var(--font-heading)] font-bold text-white leading-tight mb-3">
        {frontmatter.title}
      </h1>
      <p class="text-white/50 text-sm">
        {new Date(frontmatter.pubDate).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })} · {frontmatter.author}
      </p>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="prose max-w-none">
      <slot />
    </div>

    <footer class="mt-14 pt-8 border-t border-border">
      <div class="bg-bg-alt rounded-lg p-7 sm:p-8 text-center">
        <h3 class="text-xl sm:text-2xl font-[family-name:var(--font-heading)] font-bold text-primary mb-3">
          Bereit für ein unvergessliches Gemeinde-Event?
        </h3>
        <p class="text-text-light mb-5 max-w-lg mx-auto">
          Erfahren Sie, wie Sie kostenlos ein professionelles Musical-Konzert in Ihre Gemeinde holen.
        </p>
        <a href="/so-funktionierts" class="inline-block px-6 py-3 bg-secondary hover:bg-secondary-dark text-white font-semibold rounded-md transition-colors">
          So funktioniert's &rarr;
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
