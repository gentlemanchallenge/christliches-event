---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    author: string;
    tags: string[];
    image: string;
    imageAlt: string;
  };
}

const { frontmatter } = Astro.props;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": frontmatter.title,
  "description": frontmatter.description,
  "image": `https://christliches-event.de${frontmatter.image}`,
  "datePublished": frontmatter.pubDate,
  "author": {
    "@type": "Organization",
    "name": frontmatter.author,
  },
  "publisher": {
    "@type": "Organization",
    "name": "christliches-event.de",
    "url": "https://christliches-event.de",
  },
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogImage={frontmatter.image}
  ogType="article"
  article={{
    publishedTime: frontmatter.pubDate,
    author: frontmatter.author,
    tags: frontmatter.tags,
  }}
  jsonLd={articleJsonLd}
>
  <!-- Hero -->
  <section class="hero-gradient noise-overlay pt-32 pb-16 sm:pb-20">
    <div class="relative z-10 max-w-4xl mx-auto px-5 sm:px-8">
      <div class="mb-6">
        <Breadcrumbs items={[
          { label: 'Ratgeber', href: '/blog' },
          { label: frontmatter.title },
        ]} />
      </div>

      <div class="flex flex-wrap gap-2 mb-5">
        {frontmatter.tags.map((tag) => (
          <span class="px-3 py-1 bg-white/[0.08] text-white/60 text-xs font-medium rounded-full border border-white/10">{tag}</span>
        ))}
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-[700] font-[family-name:var(--font-heading)] text-white leading-[1.15] mb-4">
        {frontmatter.title}
      </h1>

      <p class="text-white/40 text-sm">
        {new Date(frontmatter.pubDate).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
        &middot; {frontmatter.author}
      </p>
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-5 sm:px-8 py-12 sm:py-16">
    <div class="prose max-w-none">
      <slot />
    </div>

    <footer class="mt-16 pt-10 border-t border-border">
      <div class="relative bg-bg-alt rounded-2xl p-8 sm:p-10 overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary via-secondary-light to-secondary"></div>
        <div class="text-center">
          <p class="section-label mb-3">Nächster Schritt</p>
          <h3 class="text-2xl sm:text-3xl font-[700] font-[family-name:var(--font-heading)] text-primary mb-4">
            Bereit für ein unvergessliches Gemeinde-Event?
          </h3>
          <p class="text-text-light mb-7 max-w-lg mx-auto">
            Erfahren Sie, wie Sie kostenlos ein professionelles Musical-Konzert in Ihre Gemeinde holen.
          </p>
          <a href="/so-funktionierts" class="btn-primary">
            So funktioniert's
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>
