---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTABanner from '../components/CTABanner.astro';

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "christliches-event.de",
  "url": "https://christliches-event.de",
  "description": "Ihr unabhängiger Ratgeber für christliche Gemeinde-Events.",
};

const blogPosts = [
  {
    title: "Gemeindefest planen: Die ultimative Checkliste",
    description: "Von A-Z – Zeitplan, Budget, Programm-Ideen und Helfer-Koordination für Ihr nächstes Gemeindefest.",
    slug: "gemeindefest-planen-checkliste",
    image: "/images/blog/blog-planning-checklist.jpg",
    imageAlt: "Checkliste für Gemeindefest-Planung",
    pubDate: "2026-03-18",
    tags: ["Gemeindefest", "Checkliste"],
  },
  {
    title: "Konzert in der Kirche organisieren",
    description: "Schritt-für-Schritt: GEMA, Technik, Werbung und die kostenlose Alternative für Ihre Gemeinde.",
    slug: "konzert-in-kirche-organisieren",
    image: "/images/blog/blog-music-instruments.jpg",
    imageAlt: "Musikinstrumente in einem Kirchenraum",
    pubDate: "2026-03-18",
    tags: ["Konzert", "Anleitung"],
  },
  {
    title: "Warum ein Musical-Event Gemeinden verändert",
    description: "Wie ein christliches Musical Gemeinschaft fördert und neue Menschen in Ihre Gemeinde bringt.",
    slug: "musical-event-gemeinde-veraendert",
    image: "/images/blog/blog-church-community.jpg",
    imageAlt: "Gemeinschaft in der Kirchengemeinde",
    pubDate: "2026-03-18",
    tags: ["Musical", "Gemeindeaufbau"],
  },
];
---

<BaseLayout
  title="Christliches Event für Ihre Gemeinde planen"
  description="Ihr unabhängiger Ratgeber für christliche Gemeinde-Events. Planen Sie Konzerte, Gemeindefeste und Musical-Abende – mit Praxis-Tipps und der kostenlosen Adonia-Option."
  jsonLd={websiteJsonLd}
>
  <!-- HERO -->
  <section class="relative bg-primary text-white overflow-hidden">
    <img
      src="/images/blog/blog-church-community.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/95 to-primary/80"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-32">
      <div class="max-w-2xl">
        <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-4">Ihr Ratgeber für Gemeinde-Events</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-[family-name:var(--font-heading)] font-extrabold leading-tight mb-6 text-white">
          Ein Event, das Ihre Gemeinde nachhaltig verändert
        </h1>
        <p class="text-white/70 text-lg mb-8 leading-relaxed max-w-xl">
          Erfahren Sie, wie Kirchengemeinden in ganz Deutschland mit professionellen Musical-Konzerten hunderte Menschen erreichen – kostenlos und ohne großen Aufwand.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/so-funktionierts" class="px-7 py-3.5 bg-secondary hover:bg-secondary-dark text-white font-semibold rounded-md transition-colors text-center">
            So funktioniert's &rarr;
          </a>
          <a href="/blog" class="px-7 py-3.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-md transition-colors text-center border border-white/20">
            Ratgeber lesen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ZAHLEN -->
  <section class="bg-white border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <div class="grid grid-cols-3 gap-6 sm:gap-12 text-center">
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-secondary font-[family-name:var(--font-heading)]">254+</div>
          <p class="text-text-muted text-sm mt-1">Konzerte pro Jahr</p>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-secondary font-[family-name:var(--font-heading)]">450</div>
          <p class="text-text-muted text-sm mt-1">Besucher im Schnitt</p>
        </div>
        <div>
          <div class="text-3xl sm:text-4xl font-extrabold text-secondary font-[family-name:var(--font-heading)]">0 €</div>
          <p class="text-text-muted text-sm mt-1">Kosten für Gemeinden</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEME -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Das kennen viele Gemeinden</p>
        <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold">
          Drei Herausforderungen, eine Lösung
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Wenig neue Gesichter', text: 'Der Gottesdienst erreicht die Kerngemeinde, aber darüber hinaus finden kaum neue Menschen den Weg zu Ihnen.' },
          { title: 'Knappes Budget', text: 'Professionelle Events scheinen unbezahlbar – und die wenigen Ehrenamtlichen sind schon mit dem Tagesgeschäft ausgelastet.' },
          { title: 'Jugend fehlt', text: 'Die Jugendgruppe schrumpft, Konfirmanden verschwinden danach. Wie erreicht man eine Generation, die mit Kirche wenig anfangen kann?' },
        ].map(({ title, text }) => (
          <div class="bg-white border border-border rounded-lg p-7">
            <h3 class="text-lg font-[family-name:var(--font-heading)] font-bold text-primary mb-2">{title}</h3>
            <p class="text-text-light leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LÖSUNG -->
  <section class="py-20 sm:py-24 bg-bg-alt">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Die Lösung</p>
          <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold mb-6 leading-tight">
            Ein professionelles Musical-Konzert – kostenlos in Ihrer Gemeinde
          </h2>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            Stellen Sie sich vor: 450 Menschen in Ihrem Gemeindesaal. 70 junge Musiker auf der Bühne. Ein abendfüllendes biblisches Musical mit Chor, Live-Band und Theater.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-8">
            Der Eintritt ist frei – und für Sie als Veranstalter fallen keine Kosten an. Das ist Realität in über 250 Gemeinden jedes Jahr.
          </p>
          <a href="/so-funktionierts" class="inline-flex items-center gap-2 text-accent hover:text-accent-dark font-semibold transition-colors">
            Erfahren Sie, wie es funktioniert &rarr;
          </a>
        </div>

        <div class="bg-white border border-border rounded-lg overflow-hidden">
          <div class="px-6 py-4 bg-primary text-white text-sm font-semibold">
            In 5 Schritten zum Konzert
          </div>
          <div class="p-6 space-y-5">
            {[
              { n: '1', title: 'Anfrage stellen', text: 'Kontaktieren Sie Adonia mit Ihrem Wunschtermin.' },
              { n: '2', title: 'Raum & Gastfamilien organisieren', text: 'Raum mit 350+ Plätzen und Gastfamilien bereitstellen.' },
              { n: '3', title: 'Werbung verteilen', text: 'Adonia liefert Plakate und Flyer – Sie verteilen sie.' },
              { n: '4', title: 'Konzertabend erleben', text: '70 Musiker, professionelle Technik, begeisterte Besucher.' },
              { n: '5', title: 'Kontakte nachfassen', text: 'Neue Gesichter zu Folgeangeboten einladen.' },
            ].map(({ n, title, text }) => (
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-full bg-secondary/10 text-secondary text-sm font-bold flex items-center justify-center shrink-0 mt-0.5">{n}</div>
                <div>
                  <h4 class="font-semibold text-primary text-[0.95rem]">{title}</h4>
                  <p class="text-text-light text-sm">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Erfahrungen</p>
        <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold">
          Das sagen Veranstalter
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <TestimonialCard
          quote="520 Besucher in unserer Turnhalle – mehr als bei jedem anderen Event in der Geschichte unserer Gemeinde."
          author="Pastor M."
          role="Evangelische Gemeinde, NRW"
        />
        <TestimonialCard
          quote="Der Aufwand war überschaubar. Das Ergebnis stand in keinem Verhältnis zum Aufwand. So etwas machen wir jederzeit wieder."
          author="Gemeindeleiter K."
          role="Freie Gemeinde, Baden-Württemberg"
        />
        <TestimonialCard
          quote="Die Gastfamilien waren nach dem Wochenende die größten Fans. Sie fragen schon, wann der nächste Chor kommt."
          author="Pfarrerin S."
          role="Landeskirche, Hessen"
        />
      </div>
    </div>
  </section>

  <!-- BLOG TEASER -->
  <section class="py-20 sm:py-24 bg-bg-alt">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
        <div>
          <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Wissen & Praxis</p>
          <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold">
            Ratgeber für Ihre Gemeinde
          </h2>
        </div>
        <a href="/blog" class="text-accent hover:text-accent-dark font-semibold text-sm transition-colors">
          Alle Artikel &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {blogPosts.map((post) => (
          <BlogPostCard {...post} />
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
