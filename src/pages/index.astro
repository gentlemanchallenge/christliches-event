---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTABanner from '../components/CTABanner.astro';

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "christliches-event.de",
  "url": "https://christliches-event.de",
  "description": "Ihr unabhängiger Ratgeber für christliche Gemeinde-Events.",
};

const blogPosts = [
  {
    title: "Gemeindefest planen: Die ultimative Checkliste",
    description: "Von A-Z – Zeitplan, Budget, Programm-Ideen und Helfer-Koordination für Ihr nächstes Gemeindefest.",
    slug: "gemeindefest-planen-checkliste",
    image: "/images/blog/blog-planning-checklist.jpg",
    imageAlt: "Checkliste für Gemeindefest-Planung",
    pubDate: "2026-03-18",
    tags: ["Gemeindefest", "Checkliste"],
  },
  {
    title: "Konzert in der Kirche organisieren",
    description: "Schritt-für-Schritt: GEMA, Technik, Werbung und verschiedene Konzertformate für Ihre Gemeinde.",
    slug: "konzert-in-kirche-organisieren",
    image: "/images/blog/blog-music-instruments.jpg",
    imageAlt: "Musikinstrumente in einem Kirchenraum",
    pubDate: "2026-03-18",
    tags: ["Konzert", "Anleitung"],
  },
  {
    title: "10 Wege, junge Menschen zu erreichen",
    description: "Jugendarbeit neu denken – bewährte Strategien für Pastoren und Jugendleiter.",
    slug: "junge-menschen-gemeinde-erreichen",
    image: "/images/blog/blog-teens-youth.jpg",
    imageAlt: "Gruppe junger Menschen",
    pubDate: "2026-03-18",
    tags: ["Jugendarbeit", "Gemeinde"],
  },
];
---

<BaseLayout
  title="Christliches Event für Ihre Gemeinde planen"
  description="Ihr unabhängiger Ratgeber für christliche Gemeinde-Events. Konzerte, Gemeindefeste, Jugendarbeit und Musical-Abende – mit Praxis-Tipps, Checklisten und Erfahrungsberichten."
  jsonLd={websiteJsonLd}
>
  <!-- HERO -->
  <section class="relative bg-primary text-white overflow-hidden">
    <img src="/images/blog/blog-church-community.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/95 to-primary/80"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-32">
      <div class="max-w-2xl">
        <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-4">Praxis-Ratgeber für Kirchengemeinden</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-[family-name:var(--font-heading)] font-extrabold leading-tight mb-6" style="color: #ffffff;">
          Gemeinde-Events planen, die Menschen bewegen
        </h1>
        <p class="text-white/70 text-lg mb-8 leading-relaxed max-w-xl">
          Konzerte, Gemeindefeste, Jugendarbeit, GEMA – alles, was Sie als Gemeindeleiter wissen müssen. Mit Checklisten, Erfahrungsberichten und konkreten Anleitungen.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/blog" class="px-7 py-3.5 bg-secondary hover:bg-secondary-dark text-white font-semibold rounded-md transition-colors text-center">
            Ratgeber entdecken &rarr;
          </a>
          <a href="/so-funktionierts" class="px-7 py-3.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-md transition-colors text-center border border-white/20">
            Kostenlose Konzert-Option
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- THEMEN-ÜBERSICHT -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Unsere Themen</p>
        <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold">
          Praxis-Wissen für Ihre Gemeinde
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🎵', title: 'Konzerte planen', text: 'Vom Worship-Abend bis zum Gospelkonzert – Formate, Budget, Technik und GEMA.', link: '/blog/konzert-in-kirche-organisieren' },
          { icon: '🎪', title: 'Gemeindefeste', text: 'Checklisten, Motto-Ideen, Mengenplanung und Helfer-Koordination von A-Z.', link: '/blog/gemeindefest-planen-checkliste' },
          { icon: '🎭', title: 'Musical-Events', text: 'Wie ein Musical Ihre Gemeinde öffnet – Formate, Anbieter und Praxisberichte.', link: '/blog/musical-event-gemeinde-veraendert' },
          { icon: '📋', title: 'GEMA & Recht', text: 'Evangelisch, katholisch, freikirchlich – welche Regeln für wen gelten.', link: '/blog/gema-regeln-kirchengemeinden' },
        ].map(({ icon, title, text, link }) => (
          <a href={link} class="bg-white border border-border rounded-lg p-6 hover:shadow-md transition-shadow group block">
            <div class="text-3xl mb-3">{icon}</div>
            <h3 class="text-lg font-[family-name:var(--font-heading)] font-bold text-primary mb-2 group-hover:text-accent transition-colors">{title}</h3>
            <p class="text-text-light text-sm leading-relaxed">{text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RATGEBER / BLOG -->
  <section class="py-20 sm:py-24 bg-bg-alt">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
        <div>
          <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Aktuelle Artikel</p>
          <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold">
            Leitfäden aus der Praxis
          </h2>
        </div>
        <a href="/blog" class="text-accent hover:text-accent-dark font-semibold text-sm transition-colors">
          Alle 5 Artikel &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {blogPosts.map((post) => (
          <BlogPostCard {...post} />
        ))}
      </div>
    </div>
  </section>

  <!-- HERAUSFORDERUNGEN -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Herausforderungen</p>
        <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold">
          Gemeinde-Events: viel Potenzial, oft wenig Ressourcen
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Wenig neue Gesichter', text: 'Gottesdienste erreichen die Kerngemeinde – aber wie zieht man Menschen an, die sonst nie kommen würden?' },
          { title: 'Knappes Budget', text: 'Professionelle Events kosten schnell tausende Euro. Ehrenamtliche sind mit dem Tagesgeschäft schon ausgelastet.' },
          { title: 'Jugend fehlt', text: 'Die Generation unter 30 findet kaum Zugang zu klassischen Gemeindeformaten. Neue Wege sind gefragt.' },
        ].map(({ title, text }) => (
          <div class="bg-white border border-border rounded-lg p-7">
            <h3 class="text-lg font-[family-name:var(--font-heading)] font-bold text-primary mb-2">{title}</h3>
            <p class="text-text-light leading-relaxed">{text}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <p class="text-text-light max-w-2xl mx-auto mb-4">
          Unsere Ratgeber helfen Ihnen, diese Herausforderungen zu lösen – mit konkreten Anleitungen, erprobten Ideen und realistischen Budgets.
        </p>
        <a href="/blog" class="text-accent hover:text-accent-dark font-semibold transition-colors">
          Zu den Ratgebern &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- EMPFEHLUNG: ADONIA (als ein Highlight, nicht als Hauptthema) -->
  <section class="py-20 sm:py-24 bg-bg-alt">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div>
          <p class="text-secondary font-semibold text-sm uppercase tracking-widest mb-3">Unser Tipp</p>
          <h2 class="text-3xl sm:text-4xl font-[family-name:var(--font-heading)] font-bold mb-6 leading-tight">
            Kennen Sie schon das kostenlose Konzert-Modell?
          </h2>
          <p class="text-text-light text-lg leading-relaxed mb-4">
            Es gibt Anbieter, die professionelle Musical-Konzerte komplett kostenlos in Ihre Gemeinde bringen – inklusive Chor, Band, Technik und Werbematerial. Kein Eintritt, kein Budget nötig.
          </p>
          <p class="text-text-light text-lg leading-relaxed mb-6">
            Wir haben uns das Modell genauer angeschaut und erklären auf unserer Info-Seite, wie es funktioniert, was Sie bereitstellen müssen und für welche Gemeinden es sich eignet.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/so-funktionierts" class="px-6 py-3 bg-secondary hover:bg-secondary-dark text-white font-semibold rounded-md transition-colors text-center">
              Mehr erfahren &rarr;
            </a>
            <a href="/faq" class="px-6 py-3 bg-white border border-border hover:bg-bg-alt text-text font-semibold rounded-md transition-colors text-center">
              Häufige Fragen
            </a>
          </div>
        </div>

        <div class="bg-white border border-border rounded-lg p-7">
          <h3 class="font-[family-name:var(--font-heading)] font-bold text-primary text-lg mb-5">Was Gemeinden berichten</h3>
          <div class="space-y-5">
            <div class="border-l-2 border-secondary pl-4">
              <p class="text-text-light italic text-[0.95rem] mb-2">&ldquo;520 Besucher – mehr als bei jedem anderen Event unserer Gemeinde.&rdquo;</p>
              <p class="text-text-muted text-xs">Pastor M., Evangelische Gemeinde, NRW</p>
            </div>
            <div class="border-l-2 border-secondary pl-4">
              <p class="text-text-light italic text-[0.95rem] mb-2">&ldquo;Der Aufwand war überschaubar. Das Ergebnis stand in keinem Verhältnis dazu.&rdquo;</p>
              <p class="text-text-muted text-xs">Gemeindeleiter K., Freie Gemeinde, BW</p>
            </div>
            <div class="border-l-2 border-secondary pl-4">
              <p class="text-text-light italic text-[0.95rem] mb-2">&ldquo;Die Gastfamilien fragen schon, wann der nächste Chor kommt.&rdquo;</p>
              <p class="text-text-muted text-xs">Pfarrerin S., Landeskirche, Hessen</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Planen Sie Ihr nächstes Gemeinde-Event?"
    text="In unseren Ratgebern finden Sie Checklisten, Budget-Beispiele und Praxis-Tipps für Konzerte, Feste und Jugendarbeit."
    buttonText="Ratgeber lesen →"
    buttonHref="/blog"
  />
</BaseLayout>
