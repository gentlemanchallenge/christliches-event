---
interface Props {
  title?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
  variant?: 'primary' | 'secondary';
}

const {
  title = 'Bereit für ein unvergessliches Gemeinde-Event?',
  text = 'Erfahren Sie in 5 Minuten, wie Sie ein kostenloses Musical-Konzert mit 450 Besuchern in Ihre Gemeinde holen.',
  buttonText = 'So funktioniert\'s →',
  buttonHref = '/so-funktionierts',
  variant = 'primary',
} = Astro.props;
---

<section class:list={[
  'py-20 sm:py-24',
  variant === 'primary' ? 'bg-primary text-white' : 'bg-bg-alt',
]}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class:list={[
      'text-2xl sm:text-3xl lg:text-4xl font-[family-name:var(--font-heading)] font-bold mb-4',
      variant === 'primary' ? 'text-white' : 'text-primary',
    ]}>
      {title}
    </h2>
    <p class:list={[
      'text-lg mb-8 max-w-xl mx-auto',
      variant === 'primary' ? 'text-white/70' : 'text-text-light',
    ]}>
      {text}
    </p>
    <a
      href={buttonHref}
      class:list={[
        'inline-block px-8 py-3.5 font-semibold rounded-md transition-colors text-lg',
        variant === 'primary'
          ? 'bg-secondary hover:bg-secondary-dark text-white'
          : 'bg-primary hover:bg-primary-light text-white',
      ]}
    >
      {buttonText}
    </a>
  </div>
</section>
