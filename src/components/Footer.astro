---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white/70">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="text-lg font-[family-name:var(--font-heading)] font-bold text-white">
          christliches-event<span class="text-secondary">.de</span>
        </a>
        <p class="mt-3 text-sm text-white/50 leading-relaxed">
          Ihr unabhängiger Ratgeber für christliche Gemeinde-Events.
        </p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Startseite</a></li>
          <li><a href="/so-funktionierts" class="hover:text-white transition-colors">So funktioniert's</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Ratgeber</a></li>
          <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Beliebte Artikel</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/gemeindefest-planen-checkliste" class="hover:text-white transition-colors">Gemeindefest planen</a></li>
          <li><a href="/blog/konzert-in-kirche-organisieren" class="hover:text-white transition-colors">Konzert organisieren</a></li>
          <li><a href="/blog/gema-regeln-kirchengemeinden" class="hover:text-white transition-colors">GEMA-Regeln</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Rechtliches</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/10 text-xs text-white/30 flex flex-col sm:flex-row justify-between gap-2">
      <p>&copy; {currentYear} christliches-event.de</p>
      <p>Ein unabhängiges Projekt zur Unterstützung christlicher Gemeinden.</p>
    </div>
  </div>
</footer>
