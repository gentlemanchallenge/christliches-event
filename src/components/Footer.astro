---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white/80">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="text-xl font-bold font-[family-name:var(--font-heading)] text-white">
          christliches-event<span class="text-secondary">.de</span>
        </a>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          Ihr unabhängiger Ratgeber für christliche Gemeinde-Events. Wir helfen Kirchengemeinden, unvergessliche Veranstaltungen zu planen.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Startseite</a></li>
          <li><a href="/so-funktionierts" class="hover:text-white transition-colors">So funktioniert's</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Blog -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Beliebte Artikel</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/gemeindefest-planen-checkliste" class="hover:text-white transition-colors">Gemeindefest planen</a></li>
          <li><a href="/blog/konzert-in-kirche-organisieren" class="hover:text-white transition-colors">Konzert organisieren</a></li>
          <li><a href="/blog/gema-regeln-kirchengemeinden" class="hover:text-white transition-colors">GEMA-Regeln</a></li>
          <li><a href="/blog/junge-menschen-gemeinde-erreichen" class="hover:text-white transition-colors">Junge Menschen erreichen</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Rechtliches</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-white/40">
      <p>&copy; {currentYear} christliches-event.de</p>
      <p>
        Ein unabhängiges Projekt zur Unterstützung christlicher Gemeinden.
      </p>
    </div>
  </div>
</footer>
