---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const allItems = [{ label: 'Start', href: '/' }, ...items];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": allItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    ...(item.href ? { "item": `https://christliches-event.de${item.href}` } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="text-sm text-text-light">
  <ol class="flex flex-wrap items-center gap-1">
    {allItems.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="text-text-light/40">/</span>}
        {item.href && i < allItems.length - 1 ? (
          <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
        ) : (
          <span class="text-primary font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
