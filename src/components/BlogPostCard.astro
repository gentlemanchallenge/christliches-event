---
interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  imageAlt: string;
  pubDate: string;
  tags?: string[];
}

const { title, description, slug, image, imageAlt, pubDate, tags } = Astro.props;
---

<article class="bg-white border border-border rounded-lg overflow-hidden hover:shadow-md transition-shadow group">
  <a href={`/blog/${slug}`} class="block">
    <div class="aspect-[16/10] overflow-hidden bg-bg-alt">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
        loading="lazy"
      />
    </div>
    <div class="p-5 sm:p-6">
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-3">
          {tags.slice(0, 2).map((tag) => (
            <span class="px-2.5 py-0.5 bg-bg-alt text-text-muted text-xs font-medium rounded">{tag}</span>
          ))}
        </div>
      )}
      <h3 class="text-lg font-[family-name:var(--font-heading)] font-bold text-primary mb-2 leading-snug group-hover:text-accent transition-colors">
        {title}
      </h3>
      <p class="text-text-light text-sm leading-relaxed line-clamp-2 mb-3">{description}</p>
      <span class="text-accent font-semibold text-sm">Weiterlesen &rarr;</span>
    </div>
  </a>
</article>
