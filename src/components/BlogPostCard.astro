---
interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  imageAlt: string;
  pubDate: string;
  tags?: string[];
}

const { title, description, slug, image, imageAlt, pubDate, tags } = Astro.props;
---

<article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all hover:-translate-y-1 border border-bg-alt group">
  <a href={`/blog/${slug}`} class="block">
    <div class="aspect-[16/9] overflow-hidden bg-bg-alt">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
    <div class="p-5 sm:p-6">
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-3">
          {tags.slice(0, 2).map((tag) => (
            <span class="px-2 py-0.5 bg-bg-alt text-text-light text-xs rounded-full">{tag}</span>
          ))}
        </div>
      )}
      <h3 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-primary mb-2 group-hover:text-accent transition-colors line-clamp-2">
        {title}
      </h3>
      <p class="text-text-light text-sm leading-relaxed line-clamp-3 mb-3">{description}</p>
      <span class="text-accent font-medium text-sm">
        Weiterlesen &rarr;
      </span>
    </div>
  </a>
</article>
