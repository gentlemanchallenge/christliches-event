---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Start' },
  { href: '/so-funktionierts', label: 'So funktioniert\'s' },
  { href: '/blog', label: 'Ratgeber' },
  { href: '/faq', label: 'FAQ' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<header class="bg-white border-b border-border sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-[72px]">
      <a href="/" class="font-[family-name:var(--font-heading)] text-xl font-bold text-primary">
        christliches-event<span class="text-secondary">.de</span>
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center gap-1">
        {navItems.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3.5 py-2 rounded-md text-[0.9rem] font-medium transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-primary bg-bg-alt'
                : 'text-text-light hover:text-primary hover:bg-bg-alt/60',
            ]}
          >
            {label}
          </a>
        ))}
        <a href="/kontakt" class="ml-4 px-5 py-2.5 bg-secondary hover:bg-secondary-dark text-white text-sm font-semibold rounded-md transition-colors">
          Konzert anfragen
        </a>
      </div>

      <!-- Mobile -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-text-light hover:text-primary" aria-label="Menü">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1 pt-2 border-t border-border">
        {navItems.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-2.5 rounded-md text-[0.95rem] font-medium',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-primary bg-bg-alt'
                : 'text-text-light hover:text-primary hover:bg-bg-alt/60',
            ]}
          >
            {label}
          </a>
        ))}
        <a href="/kontakt" class="mt-2 px-4 py-2.5 bg-secondary text-white font-semibold rounded-md text-center">
          Konzert anfragen
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
