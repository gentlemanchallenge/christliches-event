---
interface Props {
  icon: string;
  title: string;
  text: string;
}

const { icon, title, text } = Astro.props;
---

<div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow border border-bg-alt">
  <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center text-2xl mb-4">
    {icon}
  </div>
  <h3 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-primary mb-2">
    {title}
  </h3>
  <p class="text-text-light leading-relaxed">{text}</p>
</div>
