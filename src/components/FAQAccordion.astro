---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="space-y-0 divide-y divide-border">
  {items.map((item) => (
    <details class="group">
      <summary class="flex items-center justify-between gap-4 py-5 font-semibold text-primary hover:text-accent transition-colors cursor-pointer">
        <span class="flex-1 leading-snug">{item.question}</span>
      </summary>
      <div class="pb-5 text-text-light leading-relaxed">
        <Fragment set:html={item.answer} />
      </div>
    </details>
  ))}
</div>
