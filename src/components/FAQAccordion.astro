---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="divide-y-0">
  {items.map((item, i) => (
    <details class="group py-1">
      <summary class="flex items-center justify-between gap-4 py-5 sm:py-6 text-primary text-base sm:text-[1.05rem] cursor-pointer hover:text-accent transition-colors duration-200">
        <span class="flex-1 font-semibold leading-snug pr-4">{item.question}</span>
      </summary>
      <div class="pb-6 text-text-light leading-relaxed text-[0.95rem] pl-0 sm:pl-0">
        <Fragment set:html={item.answer} />
      </div>
    </details>
  ))}
</div>
