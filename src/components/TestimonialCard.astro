---
interface Props {
  quote: string;
  author: string;
  role: string;
}

const { quote, author, role } = Astro.props;
---

<blockquote class="bg-white border border-border rounded-lg p-6 sm:p-7 flex flex-col justify-between h-full">
  <p class="text-text leading-relaxed mb-5 italic">&ldquo;{quote}&rdquo;</p>
  <footer class="flex items-center gap-3 pt-4 border-t border-border">
    <div class="w-9 h-9 bg-primary/10 rounded-full flex items-center justify-center text-primary font-bold text-xs">
      {author.split(' ').map(n => n[0]).join('')}
    </div>
    <div>
      <cite class="not-italic font-semibold text-primary text-sm">{author}</cite>
      <p class="text-text-muted text-xs">{role}</p>
    </div>
  </footer>
</blockquote>
